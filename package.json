{
  "name": "summon",
  "version": "0.1.0",
  "type": "module",
  "description": "macOS app for switching between Ghostty terminal windows",
  "main": "src/main.ts",
  "scripts": {
    "dev": "bun run dev:vite & bun run dev:electron",
    "dev:vite": "vite --config renderer/vite.config.ts",
    "dev:electron": "bunx wait-on http://localhost:5173 && electron .",
    "build": "vite build --config renderer/vite.config.ts && electron-builder --mac"
  },
  "author": "nano",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/lodash-es": "4.17.12",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sortablejs": "1.15.9",
    "@vitejs/plugin-react": "6.0.1",
    "electron": "41.1.1",
    "electron-builder": "26.8.1",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "vite": "8.0.3",
    "wait-on": "9.0.4"
  },
  "build": {
    "appId": "nano.summon",
    "productName": "Summon",
    "mac": {
      "icon": "icons/summon.png",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "dir"
      ],
      "extendInfo": {
        "LSUIElement": true
      },
      "sign": false,
      "hardenedRuntime": false
    },
    "files": [
      "src/**/*",
      "dist-renderer/**/*",
      "icons/**/*"
    ]
  },
  "dependencies": {
    "@ricons/ionicons5": "0.13.0",
    "lodash-es": "4.18.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sortablejs": "1.15.7",
    "zustand": "5.0.12"
  }
}
